{
  "version": "1.0.0",
  "description": "Рубрика оценки качества презентации для S5_QualityValidator",
  "quality_threshold": 0.85,
  "dimensions": [
    {
      "id": "narrative",
      "name": "Нарратив",
      "weight": 0.25,
      "description": "Логическая последовательность и связность истории",
      "criteria": [
        {
          "id": "narrative_flow",
          "name": "Логическая последовательность",
          "description": "Слайды следуют друг за другом в логичном порядке",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Безупречная логика, каждый слайд естественно вытекает из предыдущего",
            "0.8": "Хорошая последовательность, 1-2 незначительных нарушения",
            "0.6": "Заметные пробелы в логике, 3-4 слайда не на своём месте",
            "0.4": "Серьёзные проблемы с последовательностью",
            "0.2": "Слайды расположены хаотично"
          }
        },
        {
          "id": "story_arc",
          "name": "Арка истории",
          "description": "Наличие чёткого начала, развития и завершения",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Полная арка: захватывающее начало, развитие, кульминация, завершение",
            "0.8": "Хорошая арка, одна часть слабее остальных",
            "0.6": "Базовая структура есть, но арка неполная",
            "0.4": "Нет чёткой арки, набор слайдов",
            "0.2": "Полное отсутствие структуры"
          }
        },
        {
          "id": "framework_compliance",
          "name": "Соответствие фреймворку",
          "description": "Презентация следует выбранному нарративному фреймворку",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Полное соответствие выбранному фреймворку",
            "0.8": "Хорошее соответствие, 1-2 отклонения",
            "0.6": "Частичное соответствие",
            "0.4": "Слабое соответствие",
            "0.2": "Фреймворк не прослеживается"
          }
        },
        {
          "id": "no_dead_slides",
          "name": "Отсутствие мёртвых слайдов",
          "description": "Каждый слайд вносит вклад в общую историю",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Все слайды необходимы и информативны",
            "0.8": "1 слайд можно удалить без потери смысла",
            "0.6": "2-3 слайда не несут ценности",
            "0.4": "Много лишних слайдов",
            "0.2": "Большинство слайдов не нужны"
          }
        }
      ]
    },
    {
      "id": "design",
      "name": "Дизайн",
      "weight": 0.25,
      "description": "Визуальное качество и консистентность",
      "criteria": [
        {
          "id": "color_consistency",
          "name": "Консистентность палитры",
          "description": "Все слайды используют цвета из определённой палитры",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Все цвета из палитры, идеальная консистентность",
            "0.8": "1-2 незначительных отклонения",
            "0.6": "Заметные отклонения от палитры",
            "0.4": "Много цветов вне палитры",
            "0.2": "Палитра не соблюдается"
          }
        },
        {
          "id": "typography_scale",
          "name": "Типографическая шкала",
          "description": "Правильное использование размеров шрифтов",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Идеальная типографическая иерархия",
            "0.8": "Хорошая иерархия, 1-2 отклонения",
            "0.6": "Заметные проблемы с размерами",
            "0.4": "Нет чёткой иерархии",
            "0.2": "Хаотичные размеры шрифтов"
          }
        },
        {
          "id": "whitespace",
          "name": "Отступы (whitespace)",
          "description": "Достаточные отступы, слайды не перегружены",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Идеальные отступы, слайды дышат",
            "0.8": "Хорошие отступы, 1-2 тесных места",
            "0.6": "Заметная перегруженность на нескольких слайдах",
            "0.4": "Большинство слайдов перегружены",
            "0.2": "Критическая перегруженность"
          }
        },
        {
          "id": "visual_hierarchy",
          "name": "Визуальная иерархия",
          "description": "Чёткая иерархия элементов на каждом слайде",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Идеальная иерархия, взгляд следует за контентом",
            "0.8": "Хорошая иерархия, 1-2 слайда с проблемами",
            "0.6": "Заметные проблемы с иерархией",
            "0.4": "Нет чёткой иерархии",
            "0.2": "Все элементы равнозначны, хаос"
          }
        },
        {
          "id": "contrast_ratio",
          "name": "Контрастность",
          "description": "Контраст текста соответствует WCAG AA (>= 4.5:1)",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Все тексты проходят WCAG AA",
            "0.8": "1-2 элемента с пограничным контрастом",
            "0.6": "Несколько элементов не проходят WCAG AA",
            "0.4": "Серьёзные проблемы с контрастом",
            "0.2": "Текст нечитаем"
          }
        }
      ]
    },
    {
      "id": "content",
      "name": "Контент",
      "weight": 0.25,
      "description": "Качество и ясность текстового содержания",
      "criteria": [
        {
          "id": "clarity",
          "name": "Ясность текста",
          "description": "Текст понятен целевой аудитории",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Кристально ясный текст, идеальный для аудитории",
