      "description": "Корректность HTML-кода и соблюдение технических требований",
      "criteria": [
        {
          "id": "valid_html",
          "name": "Валидный HTML",
          "description": "HTML-код валиден и семантичен",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Полностью валидный HTML",
            "0.8": "1-2 незначительных проблемы",
            "0.6": "Заметные проблемы с валидностью",
            "0.4": "Серьёзные проблемы",
            "0.2": "Невалидный HTML"
          }
        },
        {
          "id": "inline_styles_only",
          "name": "Только инлайновые стили",
          "description": "Нет <style> блоков и CSS-переменных",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Все стили инлайновые",
            "0.8": "1 <style> блок или CSS-переменная",
            "0.6": "Несколько нарушений",
            "0.4": "Много нарушений",
            "0.0": "Используются внешние стили"
          }
        },
        {
          "id": "no_javascript",
          "name": "Отсутствие JavaScript",
          "description": "Нет <script> тегов и inline JS",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Нет JavaScript",
            "0.0": "Есть JavaScript"
          }
        },
        {
          "id": "utf8_encoding",
          "name": "Кодировка UTF-8",
          "description": "Корректная мета-тег кодировки",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Корректный <meta charset=\"UTF-8\">",
