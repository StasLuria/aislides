            "0.6": "Заметные проблемы с ясностью",
            "0.4": "Текст сложен для понимания",
            "0.2": "Текст непонятен"
          }
        },
        {
          "id": "conciseness",
          "name": "Краткость",
          "description": "Текст лаконичен, без воды",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Идеально лаконичный текст",
            "0.8": "Хорошая краткость, 1-2 многословных места",
            "0.6": "Заметная многословность",
            "0.4": "Слишком много текста на слайдах",
            "0.2": "Слайды перегружены текстом"
          }
        },
        {
          "id": "tone_match",
          "name": "Соответствие тональности",
          "description": "Тон текста соответствует определённому в S1",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Идеальное соответствие тональности",
            "0.8": "Хорошее соответствие, 1-2 отклонения",
            "0.6": "Заметные отклонения от тона",
            "0.4": "Тон не соответствует",
            "0.2": "Полное несоответствие"
          }
        },
        {
          "id": "grammar",
          "name": "Грамматика",
          "description": "Отсутствие грамматических и орфографических ошибок",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Нет ошибок",
            "0.8": "1-2 незначительные ошибки",
            "0.6": "3-5 ошибок",
            "0.4": "Много ошибок",
            "0.2": "Критическое количество ошибок"
          }
        },
        {
          "id": "bullet_limits",
          "name": "Лимиты буллетов",
          "description": "Не более 5-7 буллетов на слайд",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Все слайды в пределах лимита",
            "0.8": "1 слайд превышает лимит",
            "0.6": "2-3 слайда превышают лимит",
            "0.4": "Большинство слайдов перегружены",
            "0.2": "Все слайды перегружены"
          }
        }
      ]
    },
    {
      "id": "technical",
      "name": "Техническое исполнение",
