          }
        },
        {
          "id": "slide_dimensions",
          "name": "Размер слайда",
          "description": "Слайд 1280x720px",
          "max_score": 1.0,
          "scoring_guide": {
            "1.0": "Корректные размеры 1280x720",
            "0.5": "Близкие, но не точные размеры",
            "0.0": "Неверные размеры"
          }
        }
      ]
    }
  ],
  "blocking_issue_rules": [
    "overall_quality_score < 0.5",
    "Любое измерение < 0.3",
    "Невалидный HTML, не отображается в браузере",
    "JavaScript в слайдах",
    "Текст нечитаем из-за контраста"
  ],
  "warning_rules": [
    "overall_quality_score < 0.85 и >= 0.5",
    "Любое измерение < 0.7 и >= 0.3",
    "Незначительные отклонения от палитры",
    "1-2 грамматические ошибки"
  ]
}
