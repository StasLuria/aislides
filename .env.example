# ═══════════════════════════════════════════════════════
# AI Presentation Generator — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# --- LLM API Keys ---
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- LLM Settings ---
LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=        # Override per-model key
# LLM_BASE_URL=       # Custom LLM endpoint

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
# JWT_EXPIRE_MINUTES=1440  # 24 hours

# --- PostgreSQL ---
POSTGRES_DB=aipres
POSTGRES_USER=aipres
POSTGRES_PASSWORD=aipres_secret

# --- Ports ---
FRONTEND_PORT=3000
# DB_PORT=5432

# --- App ---
# DEBUG=false
